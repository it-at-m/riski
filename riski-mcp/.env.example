###################
# RISKI MCP server #
###################

# Base URL of the deployed RISKI backend (required).
# Local dev example: http://localhost:8080
RISKI_MCP__BACKEND_URL=

# Optional auth header value sent to the backend (e.g. "Bearer <token>").
# Leave empty if the backend is unauthenticated. Treated as a secret.
RISKI_MCP__BACKEND_AUTH_HEADER=

# Overall timeout (seconds) for a single agent run / AG-UI stream.
RISKI_MCP__REQUEST_TIMEOUT_SECONDS=60

# httpx connect timeout (seconds).
RISKI_MCP__CONNECT_TIMEOUT_SECONDS=10

# Maximum number of sources appended to a spoken answer.
RISKI_MCP__MAX_SOURCES=3

# Verify TLS certificates. Prefer leaving true and relying on truststore for
# corporate CAs; set to false only as an escape hatch.
RISKI_MCP__VERIFY_SSL=true

# Log level for the MCP server.
RISKI_MCP__LOG_LEVEL=INFO
